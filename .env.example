# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/notifications

# AWS MSK / Kafka
# IAM: puerto 9098. SASL/SCRAM: puerto 9094.
KAFKA_BROKERS=
KAFKA_GROUP_ID=notification-service
KAFKA_TOPIC=sqyd.domain.events

KAFKA_SSL_ENABLED=true

# Opción A: MSK con IAM (cluster con "IAM role-based authentication: Enabled")
# IAM no usa usuario/contraseña de Kafka; usa credenciales AWS (Access Key + Secret Key):
KAFKA_SASL_MECHANISM=aws
KAFKA_AWS_REGION=us-east-1
# Credenciales AWS (para desarrollo local; en EC2/ECS usa el rol IAM):
#AWS_ACCESS_KEY_ID=
#AWS_SECRET_ACCESS_KEY=
# Opcional si usas credenciales temporales: AWS_SESSION_TOKEN=...

# Opción B: MSK con SASL/SCRAM (usuario/contraseña en MSK)
# KAFKA_SASL_MECHANISM=scram-sha-512
# KAFKA_SASL_USERNAME=tu-usuario
# KAFKA_SASL_PASSWORD=tu-contraseña
# KAFKA_BROKERS=...:9094 (puerto 9094 para SASL)

# JWT (misma clave/secret que Spring Boot para validar tokens)
JWT_SECRET=change-me-in-production
# Opcional: si Spring expone JWKS
# JWKS_URI=https://auth.example.com/.well-known/jwks.json

# Frontend (CORS)
FRONTEND_ORIGIN=http://localhost:3000

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100
