# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/notifications

# AWS MSK / Kafka (solo IAM, puerto 9098)
KAFKA_BROKERS=boot-xxxxx.c2.kafka-serverless.REGION.amazonaws.com:9098
KAFKA_GROUP_ID=notification-service
KAFKA_TOPIC=sqyd.domain.events
KAFKA_SSL_ENABLED=true

# Recipient JWE (obligatorio si usas Kafka): los recipients siempre vienen cifrados en JWE compacto.
# Opción A (recomendada): clave simétrica base64url (32 bytes para A256GCM con alg=dir)
KAFKA_RECIPIENT_JWE_KEY_B64URL=
# Opción B: private key PEM (si JWE usa RSA/ECDH, etc.)
# KAFKA_RECIPIENT_JWE_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Inicio de sesión AWS (IAM) para MSK — AWS solo entrega Access Key + Secret Key:
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
# AWS_SESSION_TOKEN=...   # opcional; solo para credenciales temporales (STS)

# JWT (misma clave/secret que Spring Boot para validar tokens)
JWT_SECRET=change-me-in-production
# Opcional: si Spring expone JWKS
# JWKS_URI=https://auth.example.com/.well-known/jwks.json

# Frontend (CORS)
FRONTEND_ORIGIN=http://localhost:3000

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100
