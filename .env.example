# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/notifications

# MQTT (local: Mosquitto | producción: Amazon MQ)
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_TOPIC=sqyd/domain/events
MQTT_CLIENT_ID=notification-service
# Amazon MQ: usuario y contraseña (opcional en local)
# MQTT_USERNAME=
# MQTT_PASSWORD=

# Recipient JWE (obligatorio si usas MQTT): los recipients siempre vienen cifrados en JWE compacto.
#
# --- Opción A: MQTT_RECIPIENT_JWE_KEY_B64URL (clave simétrica) ---
# Clave secreta en Base64url (sin padding). Para JWE con alg=dir y enc=A256GCM: 32 bytes (256 bits).
# Generar: openssl rand -base64 32 | tr '+/' '-_' | tr -d '='
# Ejemplo (NO usar en producción):
#   MQTT_RECIPIENT_JWE_KEY_B64URL=K7gNU3sdo-OL0wNh8oWhWhTUF0uZyOOQvStFzMcLry0
#
# --- Opción B: MQTT_RECIPIENT_JWE_PRIVATE_KEY_PEM (clave asimétrica) ---
# PEM de la clave privada (RSA o EC) en PKCS#8. Misma clave que use Spring para cifrar.
# Ejemplo RSA (una línea con \n literales o el PEM real en comillas):
#   MQTT_RECIPIENT_JWE_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFA...(base64)...\n-----END PRIVATE KEY-----"
#
MQTT_RECIPIENT_JWE_KEY_B64URL=
# MQTT_RECIPIENT_JWE_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# JWT (misma clave/secret que Spring Boot para validar tokens)
JWT_SECRET=change-me-in-production
# Opcional: si Spring expone JWKS
# JWKS_URI=https://auth.example.com/.well-known/jwks.json

# Frontend (CORS)
FRONTEND_ORIGIN=http://localhost:3000

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100
